@article{dwivedi_ExplainableAIXAI_2023,
  title        = {Explainable {{AI}} ({{XAI}}): {{Core Ideas}}, {{Techniques}}, and {{Solutions}}},
  shorttitle   = {Explainable {{AI}} ({{XAI}})},
  author       = {Dwivedi, Rudresh and {https://orcid.org/0000-0001-7836-2683} and {View Profile} and Dave, Devam and {https://orcid.org/0000-0001-7759-0684} and {View Profile} and Naik, Het and {https://orcid.org/0000-0001-7335-6209} and {View Profile} and Singhal, Smiti and {https://orcid.org/0000-0002-4653-3692} and {View Profile} and Omer, Rana and {https://orcid.org/0000-0003-3597-2646} and {View Profile} and Patel, Pankesh and {https://orcid.org/0000-0001-5973-4197} and {View Profile} and Qian, Bin and {https://orcid.org/0000-0001-7058-0360} and {View Profile} and Wen, Zhenyu and {https://orcid.org/0000-0002-2914-912X} and {View Profile} and Shah, Tejal and {https://orcid.org/0000-0001-7060-4211} and {View Profile} and Morgan, Graham and {https://orcid.org/0000-0002-0089-0395} and {View Profile} and Ranjan, Rajiv and {https://orcid.org/0000-0002-6610-1328} and {View Profile}},
