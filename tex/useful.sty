% Circled numbers with TikZ
\RequirePackage{tikz}
\DeclareRobustCommand\circled[2]{%
  \tikz[baseline=(char.base)]{
    \node[
      shape=circle, fill=#1, text=white, font=\sffamily\bfseries,
      minimum size=\f@size*1.2 pt,
      inner sep=0pt,
] (char) {\makebox[0pt][c]{#2}}; }}

% Use example color on text
\@ifclassloaded{beamer}{%
  \newcommand{\textexample}[1]{{%
      \usebeamercolor{example text}%
      \usebeamerfont{example text}%
      \textcolor{fg}{#1}%
  }}%
}{%
  \newcommand{\textexample}[1]{#1}%
}%

% New citation commands for beamer
\newcommand\blankfootnote[1]{%
  \let\thefootnote\relax\footnotetext{#1}%
  \let\thefootnote\svthefootnote%
}

\@ifclassloaded{beamer}{
  \@ifpackageloaded{biblatex}{
    \DefineBibliographyStrings{french}{
      in = {dans},
    }
    % Shared formatting logic used by both \smallfullcite and \footcite
    \newbibmacro*{fullcite:format}{%
      \mkbibbrackets{\usebibmacro{cite}}%
      \setunit{\addnbspace}%
      \printnames{labelname}%
      \setunit{\labelnamepunct}%
      \printfield[citetitle]{title}%
      \newunit%
      % Add "in" prefix for proceedings entries
      \ifboolexpr{
        test {\ifentrytype{inproceedings}} or
        test {\ifentrytype{proceedings}}
      }{\bibstring{in}\addspace}{}%
      % Venue: shortjournaltitle > journaltitle > series > booktitle
      \iffieldundef{shortjournaltitle}
      {\iffieldundef{journaltitle}
        {\iffieldundef{series}
          {\printfield{booktitle}}
        {\printfield{series}}}
      {\printfield{journaltitle}}}
      {\printfield{shortjournaltitle}}%
      \setunit{\addcomma\addspace}%
      \printfield{year}%
      \adddot%
    }

    \DeclareCiteCommand{\smallfullcite}%
    {\usebibmacro{prenote}}%
    {\usebibmacro{citeindex}%
      \usebibmacro{fullcite:format}%
    }{}{%
      \usebibmacro{postnote}%
    }

    \DeclareCiteCommand{\footcite*}%
    {\usebibmacro{prenote}}%
    {\usebibmacro{citeindex}%
      \let\svthefootnote\thefootnote%
      \let\thefootnote\relax%
      \footnotetext{\hspace{-0.8em}\hangindent=1.6em\usebibmacro{fullcite:format}}%
      \let\thefootnote\svthefootnote%
    }{}%
    {\usebibmacro{postnote}}

    \DeclareCiteCommand{\footcite}%
    {\usebibmacro{prenote}}%
    {\usebibmacro{citeindex}%
      \mkbibbrackets{\usebibmacro{cite}}%
      \ifciteseen{}{%
        \let\svthefootnote\thefootnote%
        \let\thefootnote\relax%
        \footnotetext{\hspace{-0.8em}\hangindent=1.6em\usebibmacro{fullcite:format}}%
        \let\thefootnote\svthefootnote%
      }%
    }%
    {\multicitedelim}%
    {\usebibmacro{postnote}}
  }{}
}{}